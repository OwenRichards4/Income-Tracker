# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres connection string used by Drizzle (Project Settings > Database).
# Use the pooled "Transaction" connection string for serverless/Vercel.
DATABASE_URL=

# The URL this app is actually reachable at — used to build the magic-link
# redirect. Local dev: http://localhost:3000. On Vercel: the deployed URL
# (e.g. https://your-app.vercel.app), set in the Vercel project's env vars.
NEXT_PUBLIC_SITE_URL=
